@page "/not-found"
@layout EmptyLayout
@attribute [AllowAnonymous]

<div class="min-h-screen bg-fleet-bg flex flex-col items-center justify-center">
    <p class="text-fleet-amber font-mono text-6xl font-bold mb-4">404</p>
    <p class="text-fleet-text font-mono text-xl mb-2">PAGE NOT FOUND</p>
    <p class="text-fleet-muted font-mono text-sm mb-8">The resource you're looking for doesn't exist.</p>
    <a href="/assets" class="bg-fleet-amber text-fleet-bg font-mono font-semibold px-6 py-2 rounded hover:bg-amber-400 transition-colors">
        BACK TO FLEET
    </a>
</div>