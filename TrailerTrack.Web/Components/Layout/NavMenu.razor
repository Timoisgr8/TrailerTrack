<div class="flex flex-col h-full">

    <!-- TOP: App title -->
    <div class="p-6 border-b border-fleet-border flex items-center justify-center">
        <p class="text-fleet-amber font-mono text-3xl font-bold">TRAILERTRACK</p>
    </div>

    <!-- MIDDLE: Nav links -->
    <nav class="flex-1 p-4">
        <NavLink href="/assets"
                 class="flex items-center gap-3 px-3 py-2 rounded text-fleet-muted hover:text-fleet-text hover:bg-fleet-bg transition-colors font-mono text-sm"
                 ActiveClass="text-fleet-amber bg-fleet-bg">
            FLEET
        </NavLink>
    </nav>

    <!-- BOTTOM: Logout -->
    <div class="p-4 border-t border-fleet-border">
        <form method="post" action="/logout">
            <input name="__RequestVerificationToken" type="hidden" value="@_antiforgeryToken" />
            <button type="submit"
                    class="w-full text-left px-3 py-2 font-mono text-sm text-fleet-muted hover:text-red-400 transition-colors">
                SIGN OUT
            </button>
        </form>
    </div>

</div>

@code {
    [Inject] public IAntiforgery Antiforgery { get; set; } = null!;
    [Inject] public IHttpContextAccessor HttpContextAccessor { get; set; } = null!;

    private string _antiforgeryToken = string.Empty;

    protected override void OnInitialized()
    {
        var tokens = Antiforgery.GetAndStoreTokens(HttpContextAccessor.HttpContext!);
        _antiforgeryToken = tokens.RequestToken!;
    }
}